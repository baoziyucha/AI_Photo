# 小米 MiMo API(https://platform.xiaomimimo.com 申请)
MIMO_API_KEY=sk-xxxxxxxx

# OpenAI 兼容端点
# - 按量付费(sk-):https://api.xiaomimimo.com/v1
# - Token Plan(tp-):https://token-plan-cn.xiaomimimo.com/v1
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# 模型选型:Token Plan 仅 mimo-v2.5(全能多模态)支持图片输入
# mimo-v2.5-pro/flash 为纯文本推理模型,不支持 image 输入
MODEL_GUIDANCE=mimo-v2.5
MODEL_REVIEW=mimo-v2.5

# 服务监听
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
